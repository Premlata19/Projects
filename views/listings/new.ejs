<% layout("/layouts/boilerplate") -%>
<div class="row mt-3">
  <div class="col-8 offset-2">
    <body>
      <h3>Create a New Listing</h3>
      <form
        method="POST"
        action="/listings"
        novalidate
        class="needs-validation"
        enctype="multipart/form-data"
      >
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>
          <input
            name="listing[title]"
            placeholder="Add a catchy title"
            type="text"
            class="form-control"
            required
          />
          <div class="valid-feedback">Title Looks good!</div>
        </div>

        <div class="mb-3">
          <labet for="description" class="form-label">Description</labet>
          <textarea
            name="listing[description]"
            type="text"
            class="form-control"
            required
          ></textarea>
          <div class="invalid-feedback">
            Please provide a short description.
          </div>
        </div>

        <div class="mb-3">
          <labet for="image" class="form-label">Upload listing image</labet>
          <input
            name="listing[image]"
            type="file"
            class="form-control"
            required
          />
        </div>

        <div class="row">
          <div class="mb-3 col-md-4">
            <labet for="price" class="form-label">Price</labet>
            <input
              name="listing[price]"
              placeholder="enter price"
              class="form-control"
              required
            />
            <div class="invalid-feedback">Please provide a valid price.</div>
          </div>

          <div class="mb-3 col-md-8">
            <labet for="country" class="form-label">Country</labet>
            <input
              name="listing[country]"
              placeholder="enter country"
              type="text"
              class="form-control"
              required
            />
            <div class="invalid-feedback">Please provide a valid country.</div>
          </div>
        </div>

        <div class="mb-3">
          <labet for="location" class="form-label">Location</labet>
          <input
            name="listing[location]"
            placeholder="enter location"
            type="text"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please provide a valid location.</div>
        </div>
        <button type="submit" class="btn btn-dark add-btn mt-3 mb-5">
          Add
        </button>
      </form>
    </body>
  </div>
</div>
